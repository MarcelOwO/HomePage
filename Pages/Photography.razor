@page "/Photography"

<MudPaper Class="pa-4 pa-md-15 ma-2 ma-md-10" Elevation="5">
    <MudStack>
        <MudText Typo="Typo.h2" Color="Color.Primary" Class="mb-2 project-title">Photography</MudText>
    </MudStack>
</MudPaper>

<MudPaper id="paper1" Class="pa-4 pa-md-15  ma-2 ma-md-10 " Elevation="5" gap-4 Style="overflow: hidden">
    <MudStack>
        <MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Primary">Gear</MudText>

        <MudDivider/>
        @foreach (var item in _gear)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@item</MudText>
        }
    </MudStack>
</MudPaper>

<MudPaper id="paper2" Class="pa-4 pa-md-15 ma-2 ma-md-10 " Elevation="5" gap-4 Style="overflow: hidden">
    <MudStack>
        <MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Primary">Disclaimer</MudText>
        <MudDivider/>
        <MudText Typo="Typo.body1">
            This page is still work in progress, as I am still in the process of organizing and uploading my photos. I will be adding more content and galleries in the future, so stay tuned!
        </MudText>
    </MudStack>
</MudPaper>

<MudPaper id="paper3" Class="pa-4 pa-md-15 ma-2 ma-md-10 " Elevation="5" gap-4 Style="overflow: hidden">
    <MudStack>
        <MudText Align="Align.Center" Typo="Typo.h3" Color="Color.Primary">Gallaries</MudText>
        <MudDivider/>
        <MudGrid>
            @foreach (var (link,description) in _gallaries)
            {
                <MudItem xs="6">
                    <MudPaper Class="pa-16 ma-2" Elevation="5" Square="true">
                        <MudImage ObjectFit="ObjectFit.Cover" Src=@link/>
                        <MudText Align="Align.Center" Typo="Typo.h5" Color="Color.Primary"
                                 Class="position-absolute bottom-0 start-0 p-2 bg-dark "
                                 Style="opacity: 0.7;">@description</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudStack>
</MudPaper>
@code {

    private readonly List<(string link, string description)> _gallaries = new()
    {
        
    };

    private readonly List<string> _gear =
    [
        "Camera: Sony A7r4",
        "Lens 1: Sigma 24-70mm f2.8 DG DN | Art",
        "Lens 2: Samyang 85mm f1.4 AF Series II",
        "Tripod: Rollei",
        "Gimbal: DJI RS 4",
        "Flash: Sony HVL-F46RM",
        "Microphone: Sony ECM-M1",
    ];

}
