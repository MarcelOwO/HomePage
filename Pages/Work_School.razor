@page "/WorkExperience"
@using HomePage.Components

<MudPaper Class="section-paper ma-10 pa-15" Elevation="5">
    <MudText Align="Align.Center" Typo="Typo.h2" Color="Color.Primary" Class="text-center mb-2">Education</MudText>
    <MudDivider Class="mx-auto mb-6" Style="max-width: 150px"/>

    <MudTimeline TimelinePosition="TimelinePosition.Left"
                 TimelineAlign="TimelineAlign.Default"
                 Class="pa-4">

        <TimelineItem
            Period="Oct 2025 - present"
            Title="Master, Computer Science"
            Icon="@Icons.Material.Filled.Computer"
            Organization="University of Applied Science Landshut"
            OrganizationUrl="https://www.haw-landshut.de/"
            Description="Studying algorithms, software development, and systems architecture."/>

        <TimelineItem
            Period="Oct 2021 - Sep 2025"
            Title="Bachelor, Computer Science"
            Icon="@Icons.Material.Filled.Computer"
            Organization="University of Applied Science Landshut"
            OrganizationUrl="https://www.haw-landshut.de/"
            Description="Studying algorithms, software development, and systems architecture."/>
        
        <TimelineItem
            Period="Sep 2020 - Jul 2021"
            Title="Specialized University Entrance Qualification"
            Icon="@Icons.Material.Filled.MenuBook"
            Organization="Staatliche Berufsoberschule 1 Landshut"
            OrganizationUrl="https://www.fosbos-landshut.de/"
            Description="Technical education with focus on engineering principles."/>
        
        <TimelineItem
            Period="Sep 2017 - Jul 2020"
            Title="Apprenticeship, Mechatronic"
            Icon="@Icons.Material.Filled.School"
            Organization="Flottweg SE"
            OrganizationUrl="https://www.flottweg.com/"
            Description="Gained practical skills in mechanical and electronic systems integration."/>
    </MudTimeline>

</MudPaper>

<MudPaper Class="section-paper pa-15 ma-10" Elevation="5">
    <MudText Align="Align.Center" Typo="Typo.h2" Color="Color.Primary" Class="text-center mb-2">Work Experience
    </MudText>
    <MudDivider Class="mx-auto mb-6" Style="max-width: 150px"/>

    <MudTimeline TimelinePosition="TimelinePosition.Left"
                 TimelineAlign="TimelineAlign.Default"
                 Class=" pa-4">


        <TimelineItem
            Period="Jul 2025 - Sep 2025"
            Title="Student Job"
            Icon="@Icons.Material.Filled.Mail"
            Organization="DHL Group"
            OrganizationUrl="https://group.dhl.com/en.html"
            Description="Student Job as operator of sorting machines"/>
        <TimelineItem
            Period="Nov 2023 - Jul 2024"
            Title="Internship/Working Student, Software XR Technologies"
            Icon="@Icons.Material.Filled.Engineering"
            Organization="Usaneers GmbH"
            OrganizationUrl="https://usaneers.de/"
            Description="Applied software development skills in a professional environment while balancing academic work."/>
    </MudTimeline>
</MudPaper>